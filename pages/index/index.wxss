/* 待办列表样式 */

.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(180deg, #f0f4ff 0%, #fef9f3 100%);
  padding-bottom: 150rpx;
}

/* 头部统计 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(102, 126, 234, 0.25);
}

.stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stats-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.stats-count {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.completed-stats {
  margin-top: 20rpx;
}

.completed-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 待办列表 */
.todo-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.06);
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-item.completed .todo-title {
  color: #999;
  text-decoration: line-through;
}

/* 完成按钮 */
.check-btn {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: all 0.2s;
}

.check-btn.checked {
  background: #667eea;
  border-color: #667eea;
}

.check-btn text {
  color: #fff;
  font-size: 24rpx;
}

/* 内容 */
.todo-content {
  flex: 1;
}

.todo-title {
  font-size: 32rpx;
  color: #333;
  display: block;
}

.todo-meta {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.priority {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  margin-right: 16rpx;
}

.priority-1 {
  background: #e8f5e9;
  color: #4caf50;
}

.priority-2 {
  background: #fff3e0;
  color: #ff9800;
}

.priority-3 {
  background: #ffebee;
  color: #f44336;
}

.todo-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 删除按钮 */
.delete-btn {
  padding: 12rpx 20rpx;
  background: #ffebee;
  border-radius: 16rpx;
}

.delete-btn text {
  font-size: 24rpx;
  color: #f44336;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  background: #fff;
  border-radius: 24rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

.empty-tip {
  font-size: 26rpx;
  color: #bbb;
  margin-top: 10rpx;
}

/* 底部按钮区 */
.bottom-actions {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 40rpx;
  display: flex;
  gap: 20rpx;
}

.add-btn {
  flex: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 28rpx;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
}

.calc-btn {
  flex: 1;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  padding: 28rpx;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(17, 153, 142, 0.3);
}

.exchange-btn {
  flex: 1;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 28rpx;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(240, 147, 251, 0.3);
}

.add-btn text,
.calc-btn text,
.exchange-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
}