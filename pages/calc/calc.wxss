/* 大气计算页面样式 */
.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 输入区域 */
.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.height-input {
  flex: 1;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
}

.unit {
  font-size: 28rpx;
  color: #666;
  margin-left: 16rpx;
}

.calc-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.calc-btn:active {
  opacity: 0.8;
}

/* 结果区域 */
.result-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.result-card .card-title {
  color: #fff;
  border-bottom-color: rgba(255, 255, 255, 0.2);
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.result-value {
  display: flex;
  align-items: baseline;
}

.value-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.value-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

/* 参考数据 */
.reference-list {
  display: flex;
  flex-direction: column;
}

.reference-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.reference-item:last-child {
  border-bottom: none;
}

.reference-item:active {
  background: #f9f9f9;
}

.ref-name {
  font-size: 28rpx;
  color: #333;
}

.ref-height {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* 说明 */
.tips {
  padding: 20rpx;
  background: #fff9e6;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.tips-title {
  font-size: 26rpx;
  color: #b8860b;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #8b6914;
  line-height: 1.6;
}