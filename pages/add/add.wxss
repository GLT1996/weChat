/* 添加页面样式 */

.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(180deg, #f0f4ff 0%, #fef9f3 100%);
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  font-size: 30rpx;
}

.input:focus {
  border-color: #667eea;
}

/* 优先级选择 */
.priority-options {
  display: flex;
  gap: 20rpx;
}

.priority-option {
  flex: 1;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
}

.priority-option text {
  font-size: 28rpx;
  color: #666;
}

.priority-option.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
}

.priority-option.active text {
  color: #fff;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 28rpx;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
}

.submit-btn.disabled {
  opacity: 0.5;
}

.submit-btn text {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
}